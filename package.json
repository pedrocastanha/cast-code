{
  "name": "cast-code",
  "version": "1.0.25",
  "description": "Multi-agent CLI system powered by DeepAgents",
  "main": "dist/main.js",
  "bin": {
    "cast": "./dist/main.js"
  },
  "files": [
    "dist",
    "templates",
    "scripts"
  ],
  "scripts": {
    "build": "node scripts/build-fast.mjs",
    "test": "node --test -r ts-node/register \"src/**/*.spec.ts\"",
    "typecheck": "node --max-old-space-size=6144 node_modules/typescript/bin/tsc -p tsconfig.build.json --noEmit --incremental false",
    "start": "node dist/main.js",
    "start:dev": "node scripts/start-dev.mjs",
    "smoke:benchmark-lab": "node scripts/smoke-benchmark-lab.mjs",
    "smoke:schedule": "node scripts/schedule-smoke.mjs",
    "smoke:sandbox": "node scripts/sandbox-smoke.mjs",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "langchain",
    "deepagents",
    "multi-agent"
  ],
  "author": "pedrocastanha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pedrocastanha/cast-code"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "@langchain/anthropic": "^1.3.12",
    "@langchain/core": "^1.1.24",
    "@langchain/google-genai": "^2.1.18",
    "@langchain/langgraph": "1.2.4",
    "@langchain/ollama": "^1.2.2",
    "@langchain/openai": "1.3.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^12.9.0",
    "chalk": "^4.1.2",
    "deepagents": "1.8.4",
    "diff": "^8.0.3",
    "dotenv": "^17.2.3",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "langchain": "1.2.35",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@swc/cli": "^0.5.2",
    "@swc/core": "^1.15.11",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.57.1",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "uuid": "^10.0.0"
  }
}
