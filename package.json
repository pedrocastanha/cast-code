{
  "name": "cast-code",
  "version": "1.0.27",
  "description": "Multi-agent CLI system powered by native model SDKs",
  "main": "dist/main.js",
  "bin": {
    "cast": "./dist/main.js"
  },
  "files": [
    "dist",
    "evals",
    "templates",
    "scripts"
  ],
  "scripts": {
    "build": "node scripts/build-fast.mjs",
    "test": "node --test -r ts-node/register \"src/**/*.spec.ts\"",
    "typecheck": "node --max-old-space-size=6144 node_modules/typescript/bin/tsc -p tsconfig.build.json --noEmit --incremental false",
    "start": "node dist/main.js",
    "start:dev": "node scripts/start-dev.mjs",
    "smoke:benchmark-lab": "node scripts/smoke-benchmark-lab.mjs",
    "smoke:e2e": "node scripts/e2e-cast-projects.mjs",
    "smoke:memory": "node scripts/memory-smoke.mjs",
    "smoke:schedule": "node scripts/schedule-smoke.mjs",
    "smoke:sandbox": "node scripts/sandbox-smoke.mjs",
    "smoke:bridge": "node scripts/bridge-claude-smoke.mjs",
    "smoke:agentic-runtime-v2": "node scripts/agentic-runtime-v2-smoke.mjs",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "eval:skills": "node scripts/eval-skill-selection.mjs",
    "eval:env": "node scripts/eval-environment-leaks.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "native-sdk",
    "llm",
    "multi-agent"
  ],
  "author": "pedrocastanha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pedrocastanha/cast-code"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@google/generative-ai": "^0.24.1",
    "@inquirer/prompts": "^7.3.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^12.9.0",
    "chalk": "^4.1.2",
    "diff": "^9.0.0",
    "dotenv": "^17.2.3",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "openai": "^6.39.1",
    "quickjs-emscripten": "^0.32.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@swc/cli": "^0.5.2",
    "@swc/core": "^1.15.11",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.57.1",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "uuid": "^10.0.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  }
}
